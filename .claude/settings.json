{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "dprint fmt --config /Users/sloveless/Development/projects/kamerz/dprint.jsonc \"$CLAUDE_FILE_PATH\" 2\u003e/dev/null || true",
            "type": "command"
          },
          {
            "command": "if echo \"$CLAUDE_FILE_PATH\" | grep -q 'src-tauri/.*\\.rs$'; then cd /Users/sloveless/Development/projects/kamerz/src-tauri \u0026\u0026 cargo check --message-format=short 2\u003e\u00261 | tail -5; fi",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "case \"$CLAUDE_FILE_PATH\" in */capabilities/default.json|*/Cargo.lock|*/bun.lock|*/gen/*) echo 'BLOCKED: This file should not be edited directly.' \u003e\u00262; exit 1 ;; esac; exit 0",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}