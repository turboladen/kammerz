{
	// Kammerz dprint configuration — Markdown, JSON/JSONC, TOML, and YAML.
	// The frontend/ tree is formatted by Prettier + prettier-plugin-svelte
	// (the Svelte-native formatter; see frontend/.prettierrc), and Rust by
	// rustfmt (rustfmt.toml). `just fmt` runs all three; `just fmt-check`
	// and CI's format job verify all three.
	"useTabs": true,
	"indentWidth": 2,
	"lineWidth": 120,
	"newLineKind": "lf",

	"json": {},

	// No "includes": format everything dprint has a plugin for, minus excludes.
	"excludes": [
		"**/node_modules",
		"**/target",
		"frontend", // owned by Prettier (bun run format)
		".beads",
		".claude",
	],

	"plugins": [
		"https://plugins.dprint.dev/json-0.21.3.wasm",
		"https://plugins.dprint.dev/markdown-0.22.1.wasm",
		"https://plugins.dprint.dev/toml-0.7.0.wasm",
		"https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm",
	],
}
