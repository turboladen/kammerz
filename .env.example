# Where the SQLite catalog lives on the NAS.
DATABASE_URL=sqlite:/opt/kammerz/data/kammerz.db?mode=rwc
# Argon2 hash of the single shared password.
# Generate (password read from stdin, never argv): echo -n <pw> | kammerz hash-password
# IMPORTANT: keep the single quotes — the hash is full of '$' tokens, and dotenvy
# performs $VAR substitution on unquoted (and double-quoted) values, silently
# mangling the hash so every login fails.
KAMMERZ_PASSWORD_HASH=''
# Set true only when served over HTTPS (behind a TLS reverse proxy).
SECURE_COOKIES=false
# Trust X-Forwarded-For for the login rate limiter's per-client key. Set true ONLY
# when behind a reverse proxy that REPLACES X-Forwarded-For with the single real
# client IP. The limiter reads the LEFTMOST entry, so a proxy that APPENDS (e.g.
# nginx's default `proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for`)
# is NOT safe here — an attacker sends a forged leading IP, the proxy appends the
# real one after it, and the limiter keys on the attacker's value, letting them
# mint a fresh bucket per request and defeat the throttle. Use an overwriting
# config instead, e.g. nginx `proxy_set_header X-Forwarded-For $remote_addr;`.
# Without such a proxy every request shares the proxy's IP and the limiter
# collapses to one bucket (an attacker hammering login could lock the real user
# out). Leave false on a direct LAN/VPN deployment: XFF is client-spoofable
# without an overwriting proxy. If you expose kammerz to the internet, the proxy
# should also enforce its own rate limit; kammerz is designed for LAN/VPN.
KAMMERZ_TRUST_PROXY=false
# Listen port.
PORT=3002
# Optional: overrides the claude_api_key settings row for the AI import feature.
ANTHROPIC_API_KEY=
# Pre-migration DB snapshots (kammerz.db.pre-migrate-<timestamp>, newest 5 kept)
# default ON in release builds, OFF in debug builds. Uncomment to override.
# KAMMERZ_MIGRATION_SNAPSHOTS=1
