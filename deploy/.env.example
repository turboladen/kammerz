# Kammerz production environment template.
#
# Copy this to deploy/.env (gitignored) and fill in the values, then run
# `just bootstrap <host>` — it installs deploy/.env as /opt/kammerz/.env
# (mode 600, owner kammerz). The systemd unit loads it via EnvironmentFile=
# (no `-` prefix), so /opt/kammerz/.env MUST exist or the service won't start.

# REQUIRED (unless running OPEN LAN-trust mode): argon2 hash of the single
# shared password. Generate it from the native release binary — the password is
# read from stdin, never argv, so it can't leak into shell history:
#   echo -n 'your-password' | target/release/kammerz hash-password
# Leave BLANK only to run OPEN (no auth — anyone who reaches the box gets in);
# a startup warning is logged. Set it for anything network-reachable (VPN).
KAMMERZ_PASSWORD_HASH=

# REQUIRED on the server. The unit runs with ProtectSystem=strict and only
# /opt/kammerz/data is writable (ReadWritePaths=), so the SQLite DB must live
# there. The dev default (sqlite:./kammerz.db, relative to the read-only
# WorkingDirectory) would crash-loop the service.
DATABASE_URL=sqlite:/opt/kammerz/data/kammerz.db?mode=rwc

# Session cookie Secure flag. Set true ONLY when the box is reached over HTTPS.
# Plain http:// over the LAN/VPN tunnel must leave this false (default) or the
# browser drops the session cookie and login silently fails.
# SECURE_COOKIES=true

# Listener bind address. 0.0.0.0 = all interfaces (default). Set 127.0.0.1 to
# bind loopback-only behind a reverse proxy. A malformed value fails fast.
# BIND_ADDR=0.0.0.0

# Listen port (default 3002). If you change it, pass the same port to
# `just deploy <host> <port>` so the post-deploy /api/health check hits it.
# PORT=3002

# Optional: Anthropic API key for the Claude import feature. If unset, the app
# falls back to the claude_api_key row in the settings table.
# ANTHROPIC_API_KEY=
